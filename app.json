{
  "expo": {
    "name": "NextPR",
    "slug": "mi-gym-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/main_logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo_letras_blancas.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.nextpr.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/main_logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/main_logo.png"
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "b3097a18-2f8d-46f6-af4a-c3b0398bd9c2"
      }
    }
  }
}
